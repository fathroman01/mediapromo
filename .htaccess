Options -MultiViews
RewriteEngine On
RewriteBase /

# 1. Route all API calls starting with /api/ to api.php (MUST come before file check)
RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]

# 2. Serve existing static files directly (uploads, dist assets, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. HTML5 History API fallback: all other requests go to index.html
RewriteRule ^ index.html [L]
